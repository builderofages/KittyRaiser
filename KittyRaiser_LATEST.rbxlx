function AssetIds.has(name)
    local v = AssetIds[name]
    return type(v) == "string" and v ~= "rbxassetid://0" and v ~= ""
end
function AssetIds.get(name)
    if AssetIds.has(name) then return AssetIds[name] end
    return nil
end

