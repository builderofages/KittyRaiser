          <string name="Name">PrankConfig</string>
          <string name="Source"><![CDATA[-- PrankConfig.lua
-- All prank/power types per Grok bible: Cat Scratch (starter), Pie, Hairball, Anvil, Fart, Laser, Whip, Purrgatory
